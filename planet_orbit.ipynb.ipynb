    "# 一.导入必要的科学计算和可视化库\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "from scipy.integrate import solve_ivp"
   ],
   "id": "2938ea77309d41d3",
   "outputs": [],
   "execution_count": 3
  },
  {
   "metadata": {
    "ExecuteTime": {
     "end_time": "2026-05-21T10:47:53.885769600Z",
